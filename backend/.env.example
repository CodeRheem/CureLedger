# Environment
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/cureledger
DB_NAME=cureledger

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production_at_least_32_chars
JWT_EXPIRATION=7d

# Payment (Interswitch)
INTERSWITCH_BASE_URL=https://qa.interswitchng.com/collections/api/v1/
INTERSWITCH_API_KEY=your_interswitch_api_key
INTERSWITCH_MERCHANT_CODE=your_merchant_code

# Email (Gmail)
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
EMAIL_FROM=your_gmail@gmail.com

# Logging
LOG_LEVEL=info
