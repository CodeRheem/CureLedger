# Environment
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/cureledger
DB_NAME=cureledger

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production_at_least_32_chars
JWT_EXPIRATION=7d

# Payment (Interswitch)
INTERSWITCH_BASE_URL=https://qa.interswitchng.com/collections/api/v1/
INTERSWITCH_API_KEY=
INTERSWITCH_MERCHANT_CODE=

# Email (Gmail)
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_FROM=

# Logging
LOG_LEVEL=info
